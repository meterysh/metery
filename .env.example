# Metery Environment Variables

# Comma-separated list of API keys for bearer authentication.
API_KEYS=mtr_devkey_12345,mtr_admin_abcde

# Secret for signing session cookies (any random string, min 32 chars).
SESSION_SECRET=change-me-to-a-random-secret-value

# Google OAuth2 credentials (from Google Cloud Console).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: comma-separated list of allowed email domains (e.g. "example.com,acme.org").
# If unset, any Google account can log in.
# ALLOWED_DOMAINS=example.com

# Port the HTTP server listens on.
# PORT=8080

# Set to true, 1, or yes to automatically run database migrations on server start.
MIGRATE=true

# Uncomment and change if using Postgres
# DATABASE_URL=postgres://user:pass@localhost:5432/metery?sslmode=disable
